# ─────────────────────────────────────────────────────────────────
# Infinity Fencing NW — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Spocket Drop Shipping API ─────────────────────────────────────
# Get these from: spocket.co → Settings → Developer
# Requires Spocket Empire plan ($99/mo) for API access
SPOCKET_API_URL=https://api.spocket.co
SPOCKET_CLIENT_ID=your_spocket_client_id
SPOCKET_CLIENT_SECRET=your_spocket_client_secret

# Webhook secret — set this in Spocket Developer Settings
# after registering https://yourdomain.com/api/spocket/webhook
SPOCKET_WEBHOOK_SECRET=your_webhook_secret

# ── Contact Form ──────────────────────────────────────────────────
# Used by /api/contact to send form submissions via email
# Recommended: Resend (resend.com) or SendGrid
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL=build@infinityfencingnw.com

# ── Stripe (future — for shop checkout) ──────────────────────────
# Get these from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Site ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://infinityfencingnw.com
